{
  "name": "portfolio",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json",
    "test": "vitest run",
    "cf-typegen": "wrangler types",
    "predeploy": "npm run lint && npm run typecheck && npm run test",
    "deploy": "next build && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "gray-matter": "^4.0.3",
    "next": "^15.5.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
