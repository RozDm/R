{
  "name": "portfolio",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/build-world-svg.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json",
    "test": "vitest run",
    "cf-typegen": "wrangler types",
    "predeploy": "npm run lint && npm run typecheck && npm run test",
    "deploy": "next build && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8",
    "world-map-country-shapes": "^1.0.0",
    "wrangler": "^4.99.0"
  }
}
